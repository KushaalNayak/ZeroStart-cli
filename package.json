{
    "name": "zerostart-cli",
    "displayName": "ZeroStart",
    "bin": {
        "zerostart": "out/cli.js"
    },
    "description": "Create and deploy a complete project with one command.",
    "version": "0.0.48",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "zerostart.create",
                "title": "ZeroStart"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/inquirer": "^9.0.9",
        "@types/node": "18.x",
        "@types/ora": "^3.1.0",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^6.13.1",
        "@typescript-eslint/parser": "^6.13.1",
        "eslint": "^8.54.0",
        "typescript": "^5.3.2"
    },
    "dependencies": {
        "@octokit/rest": "^19.0.13",
        "chalk": "^4.1.2",
        "commander": "^14.0.3",
        "fs-extra": "^11.3.3",
        "inquirer": "^9.3.8",
        "open": "^8.4.2",
        "openai": "^6.25.0",
        "ora": "^5.4.1"
    }
}
